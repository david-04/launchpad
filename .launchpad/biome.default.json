{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "files": {
        "ignoreUnknown": true
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "off"
            }
        }
    },
    "formatter": {
        "formatWithErrors": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120,
        "expand": "never",
        "useEditorconfig": true
    },
    "javascript": {
        "parser": {
            "unsafeParameterDecoratorsEnabled": true,
            "jsxEverywhere": false
        },
        "formatter": {
            "quoteProperties": "asNeeded",
            "trailingCommas": "es5",
            "arrowParentheses": "asNeeded",
            "operatorLinebreak": "before"
        }
    },
    "linter": {
        "enabled": false
    },
    "json": {
        "parser": {
            "allowComments": true,
            "allowTrailingCommas": true
        }
    },
    "css": {
        "formatter": {
            "enabled": true
        }
    },
    "html": {
        "parser": {
            "interpolation": true
        },
        "formatter": {
            "enabled": true
        }
    },
    "graphql": {
        "formatter": {
            "enabled": true
        }
    }
}
